<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>下関海響マラソン フルマラソンコース</name>
    <description>オーヴィジョン海峡通りを発着点とするフルマラソンコース</description>
    <Style id="marathonLine">
      <LineStyle>
        <color>ff0000ff</color>
        <width>4</width>
      </LineStyle>
    </Style>
    <Placemark>
      <name>スタート/フィニッシュ：オーヴィジョン海峡通り</name>
      <Point>
        <coordinates>130.931472,33.951528,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>長府外浦町折返し（約10.5km地点）</name>
      <Point>
        <coordinates>131.002222,33.985250,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>彦島大橋（絶景ポイント）</name>
      <Point>
        <coordinates>130.916111,33.943056,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>長州出島（約25km地点）</name>
      <Point>
        <coordinates>130.892778,34.004167,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>梶栗ランプ折返し（約31km地点）</name>
      <Point>
        <coordinates>130.908056,34.032222,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>マラソン経路</name>
      <styleUrl>#marathonLine</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          130.931472,33.951528,0
          130.960278,33.962222,0
          131.002222,33.985250,0
          130.945000,33.958056,0
          130.925000,33.940000,0
          130.916111,33.943056,0
          130.892778,34.004167,0
          130.908056,34.032222,0
          130.916111,33.943056,0
          130.920000,33.925000,0
          130.931472,33.951528,0
        </coordinates>
      </LineString>
    </Placemark>
  </Document>
